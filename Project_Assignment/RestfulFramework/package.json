{
  "name": "restful-api-automation-framework",
  "version": "1.0.0",
  "description": "Production-ready RESTful API test automation framework using Playwright (TypeScript) with two-page object model",
  "scripts": {
    "test": "playwright test",
    "test:users": "playwright test tests/users/",
    "test:posts": "playwright test tests/posts/",
    "test:report": "playwright show-report",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^25.9.2",
    "dotenv": "^16.4.5",
    "typescript": "^5.4.5"
  }
}
